RewriteEngine On
RewriteBase /r/

# 管理画面・静的ファイル・APIはそのまま通す
RewriteCond %{REQUEST_URI} ^/r/admin/ [OR]
RewriteCond %{REQUEST_URI} ^/r/api/ [OR]
RewriteCond %{REQUEST_URI} ^/r/assets/ [OR]
RewriteCond %{REQUEST_URI} ^/r/includes/ [OR]
RewriteCond %{REQUEST_URI} ^/r/templates/ [OR]
RewriteCond %{REQUEST_URI} ^/r/vendor/ [OR]
RewriteCond %{REQUEST_URI} ^/r/install/ [OR]
RewriteCond %{REQUEST_URI} ^/r/cv\.php [OR]
RewriteCond %{REQUEST_URI} ^/r/ref_cv\.php
RewriteRule ^ - [L]

# 紹介リダイレクト: /ref/SLUG → ref.php?campaign=SLUG
RewriteRule ^ref/([a-zA-Z0-9_-]+)/?$ ref.php?campaign=$1 [L,QSA]

# 実ファイル/ディレクトリが存在する場合はそのまま
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 拡張子付き (.htm, .html) のリクエスト
RewriteRule ^(.+?)\.(htm|html)$ index.php?slug=$1&ext=$2 [L,QSA]

# ディレクトリ風 (末尾スラッシュ)
RewriteRule ^(.+)/$ index.php?slug=$1&ext=dir [L,QSA]

# それ以外
RewriteRule ^(.+)$ index.php?slug=$1 [L,QSA]
